{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!**/node_modules", "!**/dist"]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              [":PACKAGE:"],
              ":BLANK_LINE:",
              "src/**",
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 90
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        // Allow auto-fixing of unused imports.
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        },
        // Allow auto-fixing of unused variables.
        "noUnusedVariables": "error"
      },
      "a11y": {
        // Don't require SVGs to have titles.
        "noSvgWithoutTitle": "off"
      },
      "suspicious": {
        // Allow array index keys.
        "noArrayIndexKey": "off"
      },
      "style": {
        // Enforce curly braces around single-line if statements.
        "useBlockStatements": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      // Enable Tailwind CSS directives.
      "tailwindDirectives": true
    }
  }
}
